# Generated by Ansible — do not edit directly (edit ansible/templates/docker-compose.yml.j2)
services:

  # Aggregate container: mounts ALL repositories
  devcontainer-all:
    build:
      context: "{{ master_repo_dest }}/devcontainer"
      args:
        USER_UID: "{{ container_uid }}"
        USER_GID: "{{ container_gid }}"
    image: devcontainer:latest
    container_name: devcontainer-all
    restart: unless-stopped
    profiles: [all]
    volumes:
      - "{{ claude_config_path }}:/home/coder/.claude"
      - "{{ master_repo_dest }}:/repo"
      - devcontainer-all-config:/home/coder/.config
      - "{{ home_path }}/.ssh:/home/coder/.ssh:ro"
    environment:
      - PASSWORD=${WORKSPACE_PASSWORD}
    ports:
      - "{{ base_port }}:8080"
      - "3000:3000"
    extra_hosts:
      - "host.docker.internal:{{ host_docker_internal_ip }}"
    command: --auth password /repo/repositories

{% for project in projects %}
  # Per-project container: mounts full repo so submodule gitfiles resolve correctly
  devcontainer-{{ project.name }}:
    image: devcontainer:latest
    container_name: devcontainer-{{ project.name }}
    restart: unless-stopped
    profiles: ["{{ project.name }}"]
    volumes:
      - "{{ claude_config_path }}:/home/coder/.claude"
      - "{{ master_repo_dest }}:/repo"
      - devcontainer-{{ project.name }}-config:/home/coder/.config
      - "{{ home_path }}/.ssh:/home/coder/.ssh:ro"
    environment:
      - PASSWORD=${WORKSPACE_PASSWORD}
    ports:
      - "{{ project.port }}:8080"
    extra_hosts:
      - "host.docker.internal:{{ host_docker_internal_ip }}"
    command: --auth password /repo/repositories/{{ project.name }}

{% endfor %}

volumes:
  devcontainer-all-config:
{% for project in projects %}
  devcontainer-{{ project.name }}-config:
{% endfor %}
